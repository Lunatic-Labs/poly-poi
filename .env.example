# Copy this file to .env.local and fill in values.
#
# OPTION A — Shared cloud project (recommended for most developers)
#   Get these values from the project owner, or create a free project at supabase.com.
#   No Docker required.
#
# OPTION B — Local Supabase (optional, requires Docker Desktop)
#   Run: supabase start
#   Then: supabase status  (prints all the values below)
#   Local DATABASE_URL: postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Direct Postgres connection for SQLAlchemy (find in Supabase dashboard → Settings → Database)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
VISITOR_APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
